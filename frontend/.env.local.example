# Local-only Next.js environment.
#
# This file is committed; copy it to .env.local and adjust values as needed.
# Names without the NEXT_PUBLIC_ prefix are SERVER-ONLY: they never reach the
# browser. The app intentionally does not expose ACU_BACKEND_URL to the
# browser — Route Handlers under app/api/* proxy to Django on the server side.
#
# When running Next inside Docker Compose alongside Django, point this at the
# Compose service name (e.g. http://web:8000); for ``manage.py runserver`` on
# the host, use http://127.0.0.1:8000.

ACU_BACKEND_URL=http://127.0.0.1:8000

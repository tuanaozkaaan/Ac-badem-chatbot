# Copy to `.env` (same directory) before running `docker compose up`.
# Compose will refuse to start if any of the required variables below are missing.
#
# Variables marked REQUIRED have no safe default. Variables marked OPTIONAL have sensible
# fallbacks defined in docker-compose.yml / settings.py.

###############################################################################
# Django
###############################################################################

DJANGO_SETTINGS_MODULE=acu_chatbot.settings

# REQUIRED: cryptographic secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Settings refuses to boot with the dev placeholder when DJANGO_DEBUG=0.
DJANGO_SECRET_KEY=replace-me-with-a-strong-random-string

# OPTIONAL: 1 = development (verbose errors, permissive CORS), 0 = production hardening.
# Defaults to 0 in settings.py; the dev override sets it to 1.
DJANGO_DEBUG=1

# REQUIRED in production: explicit comma-separated list of host names. "*" is rejected
# by settings.py when DJANGO_DEBUG=0.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# REQUIRED in production: comma-separated origins (scheme + host + optional port) that may
# call the API from a browser. Leave empty in development.
DJANGO_CORS_ALLOWED_ORIGINS=

###############################################################################
# PostgreSQL (REQUIRED — no insecure defaults remain in code or compose)
###############################################################################

POSTGRES_DB=acibadem_db
POSTGRES_USER=acibadem
POSTGRES_PASSWORD=ctrl+tab

# Used only when running Django on the host (outside Compose). Inside Compose the
# `web` service connects to host=db, port=5432 over the internal network.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# OPTIONAL: dev-only host port mapping for the db container (override file uses this).
POSTGRES_EXPOSE_PORT=5433

###############################################################################
# RAG / embedding retrieval (optional)
###############################################################################

# Minimum cosine similarity (0–1) for vector hits; default 0.55 (Adım 4.4 calibrated
# against paraphrase-multilingual-MiniLM-L12-v2; in-scope band 0.62–0.84,
# noise band 0.36–0.47). If no row meets this, the retriever falls back to
# top-k anyway (see chatbot/services/embedding.py).
# Set lower (e.g. 0.50) for more permissive matches; higher (e.g. 0.60) for tighter recall.
# ACU_EMBEDDING_MIN_COSINE=0.55


###############################################################################
# Ollama (local LLM)
###############################################################################

# OPTIONAL: model tag pulled into the ollama container. Default targets the Gemma 7B upgrade.
OLLAMA_MODEL=gemma:7b

# OPTIONAL: how long the model stays resident after the last request.
OLLAMA_KEEP_ALIVE=10m

###############################################################################
# Gunicorn (production runtime; ignored when DJANGO_DEBUG=1)
###############################################################################

# OPTIONAL: keep low to avoid memory pressure when running a local 7B model.
GUNICORN_WORKERS=2

# OPTIONAL: must comfortably exceed the slowest /ask round-trip including LLM cold start.
GUNICORN_TIMEOUT=300

###############################################################################
# Web service
###############################################################################

# OPTIONAL: host port published for the Django service (container always listens on 8000).
WEB_HOST_PORT=8001

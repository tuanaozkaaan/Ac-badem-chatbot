## Django
DJANGO_SETTINGS_MODULE=acu_chatbot.settings
DJANGO_SECRET_KEY=django-insecure-dev-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

## PostgreSQL (choose ONE approach)
#
# Approach A (recommended): use the Postgres container from docker-compose on your host.
# The db service is exposed on localhost:${POSTGRES_EXPOSE_PORT:-5433}
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=acibadem
POSTGRES_USER=acibadem
POSTGRES_PASSWORD=acibadem
#
# Approach B: use your local Postgres installation (default port 5432).
# In that case, create the role+db (see README) and set:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=acibadem
# POSTGRES_USER=acibadem
# POSTGRES_PASSWORD=acibadem
